@using RentACar.Models
@model List<User>
@{
    ViewData["Title"] = "Управление на потребители";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2"></i>Потребители</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Назад
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Потр. име</th>
                <th>Имe</th>
                <th>ЕГН</th>
                <th>Телефон</th>
                <th>Имейл</th>
                <th>Роля</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td><strong>@user.Username</strong></td>
                    <td>@user.FirstName @user.LastName</td>
                    <td><code>@user.Egn</code></td>
                    <td>@user.Phone</td>
                    <td>@user.Email</td>
                    <td>
                        <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                            @user.Role
                        </span>
                    </td>
                    <td>
                        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>