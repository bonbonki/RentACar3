@using RentACar.ViewModels
@model AdminUserViewModel
@{
    ViewData["Title"] = "Редактирай потребител";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="bi bi-person-gear me-2"></i>Редактирай потребител</h4>
            </div>
            <div class="card-body">
                <form asp-action="EditUser" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">Собствено име</label>
                            <input asp-for="FirstName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Фамилно име</label>
                            <input asp-for="LastName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label">Потребителско име</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Имейл</label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Egn" class="form-label">ЕГН</label>
                            <input asp-for="Egn" class="form-control" maxlength="10" />
                            <span asp-validation-for="Egn" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Телефон</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label">Роля</label>
                            <select asp-for="Role" class="form-select">
                                <option value="User">User</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label">
                                Нова парола <span class="text-muted">(оставете празно за непромяна)</span>
                            </label>
                            <input asp-for="NewPassword" class="form-control" type="password" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning">Запази</button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Откажи</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>