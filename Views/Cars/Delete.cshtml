@using RentACar.Models
@model Car
@{
    ViewData["Title"] = "Изтрий автомобил";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-trash me-2"></i>Изтрий автомобил</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Сигурни ли сте, че искате да изтриете следния автомобил?
                </div>
                <table class="table table-bordered">
                    <tr><th>Марка</th><td>@Model.Brand</td></tr>
                    <tr><th>Модел</th><td>@Model.Model</td></tr>
                    <tr><th>Година</th><td>@Model.Year</td></tr>
                    <tr><th>Цена/ден</th><td>@Model.PricePerDay лв.</td></tr>
                </table>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Да, изтрий
                    </button>
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Откажи</a>
                </form>
            </div>
        </div>
    </div>
</div>

