@using RentACar.Models
@model Car
@{
    ViewData["Title"] = "Добави автомобил";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Добави автомобил</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="mb-3">
                        <label asp-for="Brand" class="form-label">Марка</label>
                        <input asp-for="Brand" class="form-control" placeholder="Toyota" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Model" class="form-label">Модел</label>
                        <input asp-for="Model" class="form-control" placeholder="Corolla" />
                        <span asp-validation-for="Model" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Year" class="form-label">Година</label>
                            <input asp-for="Year" class="form-control" type="number" min="1990" max="2030" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Seats" class="form-label">Брой места</label>
                            <input asp-for="Seats" class="form-control" type="number" min="1" max="20" />
                            <span asp-validation-for="Seats" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PricePerDay" class="form-label">Цена на ден (лв.)</label>
                        <input asp-for="PricePerDay" class="form-control" type="number" step="0.01" min="1" />
                        <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Описание <span class="text-muted">(по избор)</span></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Техническа информация..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Добави</button>
                        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Откажи</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

