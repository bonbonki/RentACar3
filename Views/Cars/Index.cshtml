@using RentACar.Models
@model List<Car>
@{
    ViewData["Title"] = "Автомобили";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-car-front me-2"></i>Нашите автомобили</h2>
    @if (Context.Session.GetString("Role") == "Admin")
    {
        <a asp-controller="Cars" asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i>Добави автомобил
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var car in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-car-front text-primary me-2"></i>@car.Brand @car.Model
                    </h5>
                    <ul class="list-unstyled text-muted small mb-2">
                        <li><i class="bi bi-calendar3 me-1"></i>Година: <strong>@car.Year</strong></li>
                        <li><i class="bi bi-people me-1"></i>Места: <strong>@car.Seats</strong></li>
                    </ul>
                    @if (!string.IsNullOrEmpty(car.Description))
                    {
                        <p class="card-text small text-muted">@car.Description</p>
                    }
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-success fs-5">@car.PricePerDay лв./ден</span>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-primary">Детайли</a>
                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-outline-warning">Редакция</a>
                                <a asp-action="Delete" asp-route-id="@car.Id" class="btn btn-outline-danger">Изтрий</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
