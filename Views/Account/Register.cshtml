@using RentACar.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i>Регистрация</h4>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">Собствено име</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Иван" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Фамилно име</label>
                            <input asp-for="LastName" class="form-control" placeholder="Иванов" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label">Потребителско име</label>
                            <input asp-for="Username" class="form-control" placeholder="ivan123" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Имейл</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="ivan@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Egn" class="form-label">ЕГН</label>
                            <input asp-for="Egn" class="form-control" placeholder="0000000000" maxlength="10" />
                            <span asp-validation-for="Egn" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Телефон</label>
                            <input asp-for="Phone" class="form-control" placeholder="+359888123456" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label">Парола</label>
                            <input asp-for="Password" class="form-control" type="password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label">Потвърди парола</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-dark w-100 mt-4">Регистрирай се</button>
                </form>
            </div>
            <div class="card-footer text-center">
                Вече имате акаунт? <a asp-action="Login">Влезте тук</a>
            </div>
        </div>
    </div>
</div>
